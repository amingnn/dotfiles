#!/bin/sh
set -eu

{{ if ne .chezmoi.os "darwin" }}
exit 0
{{ end }}

if ! command -v brew >/dev/null 2>&1; then
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi
command -v brew >/dev/null 2>&1 || {
  echo "[chezmoi] 未找到 brew；请先安装 Homebrew，或把 brew 加入 PATH。" >&2
  exit 1
}

tmp="${TMPDIR:-/tmp}/Brewfile.chezmoi.$$"
trap 'rm -f "$tmp"' EXIT INT TERM HUP

cat >"$tmp" <<'EOF'
{{ range .packages.darwin.homebrew.taps }}
tap "{{ . }}"
{{ end }}
{{ range .packages.darwin.homebrew.brew }}
brew "{{ . }}"
{{ end }}
{{ range .packages.darwin.homebrew.casks }}
cask "{{ . }}"
{{ end }}
EOF

echo "[chezmoi] 正在通过 brew bundle 安装 Homebrew 软件包..."
brew bundle --file="$tmp"
