#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["requests", "rich"]
# ///
import argparse
import os
import sys
import requests

from rich.console import Console
from rich.columns import Columns

def _print_pretty(ids):
    console = Console()
    if not ids:
        console.print("[yellow](空)[/yellow]")
        return

    ids = sorted(ids)
    idx_w = len(str(len(ids)))
    items = [f"[green]{str(i).rjust(idx_w)}.[/green] {mid}" for i, mid in enumerate(ids, 1)]
    
    console.print(Columns(items, equal=True, expand=False, column_first=True))


def _read_data(api_url, api_key, path):
    base = (api_url or "").rstrip("/")
    if not base:
        raise SystemExit("错误: 缺少 api_url (通过参数或环境变量 NEW_API 提供)。")
    if not api_key:
        raise SystemExit("错误: 缺少 api_key (通过参数或环境变量 NEW_API_KEY 提供)。")

    # 根据 path 参数动态构建 URL
    url = f"{base}/{path.lstrip('/')}"
    
    try:
        response = requests.get(
            url, 
            headers={"Authorization": f"Bearer {api_key}"},
            timeout=15,
            verify=False  # 保持测试脚本的灵活性
        )
        response.raise_for_status()
        payload = response.json()
    except Exception as e:
        raise SystemExit(f"请求或解析失败: {e}")

    # 兼容 OpenAI /models 标准和某些 API 的 /tags 结构
    data = payload.get("data", payload if isinstance(payload, list) else [])
    
    if not isinstance(data, list):
        return []
        
    # 提取 ID (兼容对象列表或字符串列表)
    return [
        item.get("id") if isinstance(item, dict) else str(item) 
        for item in data 
        if (isinstance(item, dict) and item.get("id")) or isinstance(item, str)
    ]


def main(argv=None):
    parser = argparse.ArgumentParser(prog="models", add_help=True)
    parser.add_argument("api_url", nargs="?", default=os.getenv("NEW_API"), help="API base URL")
    parser.add_argument("api_key", nargs="?", default=os.getenv("NEW_API_KEY"), help="API key")
    parser.add_argument("-p", "--path", default="models", help="API endpoint path (default: models, e.g., tags)")
    
    args = parser.parse_args(argv)

    ids = _read_data(args.api_url, args.api_key, args.path)
    
    console = Console()
    console.print(f"\n[bold blue]{args.api_url}[/bold blue] (/{args.path}) 支持列表：")
    console.print(f"共 [bold green]{len(ids)}[/bold green] 个条目")
    _print_pretty(ids)
    print() 
    return 0


if __name__ == "__main__":
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    raise SystemExit(main())