#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "requests>=2.31",
# ]
# ///
"""
用 requests 对一个 URL 发起 GET，并把请求/响应头打印出来。

用法：
  get URL

选项：
  -h, --head    只输出响应头
  -s, --status  只输出状态码
  -H, --header  追加请求头（可重复，格式：'Key: Value'）
  --help        显示帮助
"""

import argparse
import sys

import requests


def _parse_headers(items):
    headers = {}
    for raw in items or []:
        k, sep, v = raw.partition(":")
        if not sep:
            raise ValueError(f"无效 header（需要 'Key: Value'）：{raw}")
        headers[k.strip()] = v.lstrip()
    return headers


def get(url, *, headers=None):
    try:
        response = requests.get(url, headers=headers, verify=False)
        return response
    except Exception as e:
        print(f"请求失败: {e}")
        return None


def main(argv=None):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-h", "--head", action="store_true", help="只输出响应头")
    parser.add_argument("-s", "--status", action="store_true", help="只输出状态码")
    parser.add_argument(
        "-H",
        "--header",
        action="append",
        default=[],
        help="追加请求头（可重复，格式：'Key: Value'）",
    )
    parser.add_argument("--help", action="help", help="显示帮助")
    parser.add_argument("url")
    args = parser.parse_args(argv)

    try:
        headers = _parse_headers(args.header)
    except ValueError as e:
        print(str(e))
        return 2

    response = get(args.url, headers=headers or None)
    if response is None:
        return 1

    if args.head or args.status:
        if args.head:
            for k, v in response.headers.items():
                print(f"{k}: {v}")
        if args.status:
            print(response.status_code)
        return 0

    try:
        sys.stdout.write(response.text)
    except UnicodeEncodeError:
        sys.stdout.buffer.write(response.content)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
