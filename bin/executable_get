#!/bin/sh
#
# 对一个 URL 发起请求，并把请求头/响应头打印出来。
#
# 设计目标：
# - 够“直白”：只基于 curl 的 verbose 输出做轻度整理。
# - 够“可调试”：默认只打印 headers；需要看 body 时用 --context。
#
# 用法：
#   get [--context|-c] [curl 参数...] URL
#
# 选项：
#   --context, -c   额外打印响应内容（response body）。注意：二进制内容会原样输出。

set -e

context=0

usage() {
  echo "用法：get [--context|-c] [curl 参数...] URL" >&2
}

while [ $# -gt 0 ]
do
  case "$1" in
    --context|-c)
      context=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [ $# -lt 1 ]
then
  echo "错误：缺少 URL。" >&2
  usage
  exit 2
fi

tmp_body="$(mktemp -t get.body.XXXXXX)"
tmp_v="$(mktemp -t get.verbose.XXXXXX)"

cleanup() {
  rm -f "$tmp_body" "$tmp_v"
}
trap cleanup EXIT INT TERM

# curl 的 -v 输出走 stderr；body 走 stdout。
# 这里把两者分开存下来，再做格式化输出。
set +e
curl -sS -v "$@" >"$tmp_body" 2>"$tmp_v"
status=$?
set -e

awk '
  BEGIN { req_n=0; res_n=0; in_req=0; in_res=0 }
  /^\* / { next }

  /^> / {
    line=$0
    sub(/^> /, "", line)
    if (!in_req) { req_n++; print "# --- Request " req_n " ---"; in_req=1 }
    print line
    if (line == "") { in_req=0; print "" }
    next
  }

  /^< / {
    line=$0
    sub(/^< /, "", line)
    if (!in_res) { res_n++; print "# --- Response " res_n " ---"; in_res=1 }
    print line
    if (line == "") { in_res=0; print "" }
    next
  }
  {
    # 其它 verbose 行（比如 TLS/连接细节）默认不打印，避免噪音。
    next
  }
' "$tmp_v"

if [ "$context" -eq 1 ]
then
  echo "# --- Body ---"
  cat "$tmp_body"
fi

exit "$status"
