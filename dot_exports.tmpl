#!/bin/sh
{{- if .proxy }}
# 代理
export http_proxy={{ .proxy | quote }}
export https_proxy={{ .proxy | quote }}
{{ end -}}

# 隐藏brew install时的信息
export HOMEBREW_NO_ENV_HINTS=1

# PATH
export PATH="$HOME/bin:$PATH" # add my bin path
export PATH="$HOME/.bun/bin:$PATH" # add bun path

# 环境变量
export MANPATH="/usr/local/man:$MANPATH"
export EDITOR='code'


