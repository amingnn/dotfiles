{{- /* 1. 定义变量并设置默认值 */ -}}
{{- $proxy_default := "http://127.0.0.1:7897" -}}

{{- /* 2. 交互式询问：如果存在则跳过，不存在则显示默认值供确认 */ -}}
{{- $git_name := promptStringOnce . "git_name" "输入你的姓名用于git配置" -}}
{{- $git_email := promptStringOnce . "git_email" "输入你的邮箱用于git配置" -}}
{{- $proxy := promptStringOnce . "proxy" "请输入代理地址" $proxy_default -}}

diff:
  pager: "cat"

edit:
  command: "code"
  args: ["--wait"]

data:
  git_name: {{ $git_name }}
  git_email: {{ $git_email }}
  proxy: {{ $proxy | quote }}